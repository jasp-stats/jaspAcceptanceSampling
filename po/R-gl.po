msgstr "Media Mostral"

msgid "Sample Standard Deviation"
msgstr "Desvío Padrón Mostral"

msgid "Historical Standard Deviation"
msgstr "Desvío Padrón Histórico"

msgid "Lower Specification Limit (LSL)"
msgstr "Límite Inferior de Especificación (LIE, LSL)"

msgid "Upper Specification Limit (USL)"
msgstr "Límite Superior de Especificación (LSE, USL)"

msgid "Z.LSL"
msgstr "Z.LIE"

msgid "Z.USL"
msgstr "Z.LSE"

msgid "Sample standard deviation has to be greater than 0."
msgstr "O desvío padrón mostral ten que ser maior que 0."

msgid "Sample mean is invalid."
msgstr "A media mostral non é válida."

msgid "Can not accept or reject lot: sample size has to be greater than 1."
msgstr ""
"Non se pode aceptar nin rexeitar o lote: o tamaño da mostra ten que ser "
"maior que 1."

msgid ""
"Sample size has to be <b>> 1</b> if <b>both</b> LSL and USL are provided, "
"and historical standard deviation is <b>unknown</b>."
msgstr ""
"O tamaño mostral ten que ser <b>> 1</b> cando se indican <b>tanto</b> LIE "
"como LSE, e o desvío padrón histórico é <b>descoñecido</b>."

msgid "<u>Decision:</u> <b>%s</b> lot."
msgstr "<u>Decisión:</u> <b>%s</b> lote."

#~ msgid ""
#~ "Lot size (N = %.0f) cannot be smaller than the sample size (n = %.0f) of "
#~ "the generated variable plan."
#~ msgstr ""
#~ "O tamaño do lote (N = %.0f) non pode ser menor que o tamaño da mostra (n "
#~ "= %.0f) do plan de variables xerado."
