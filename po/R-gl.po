msgid ""
"Z.LSL = (mean - LSL) / historical standard deviation\n"
"\n"
"Accept lot if Z.LSL >= k, otherwise reject."
msgstr ""
"Z.LSL = (media - LSL) / desvío padrón histórico\n"
"\n"
"Acepta o lote se Z.LSL >= k; en caso contrario, rexeitar."

