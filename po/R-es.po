msgstr "Aceptar o Rechazar Lote %s"

msgid "Sample Mean"
msgstr "Media Muestral"

msgid "Sample Standard Deviation"
msgstr "Desviación Típica Muestral"

msgid "Historical Standard Deviation"
msgstr "Desviación Típica Histórica"

msgid "Lower Specification Limit (LSL)"
msgstr "Límite Inferior de Especificación (LIE,LSL)"

msgid "Upper Specification Limit (USL)"
msgstr "Límite Superior de Especificación (LSE, USL)"

msgid "Z.LSL"
msgstr "Z.LIE"

msgid "Z.USL"
msgstr "Z.LSE"

msgid "Sample standard deviation has to be greater than 0."
msgstr "La desviación típica muestral tiene que ser mayor que 0."

msgid "Sample mean is invalid."
msgstr "La media muestral no es válida."

msgid "Can not accept or reject lot: sample size has to be greater than 1."
msgstr ""
"No se puede aceptar ni rechazar el lote: el tamaño de la muestra tiene que "
"ser mayor que 1."

msgid ""
"Sample size has to be <b>> 1</b> if <b>both</b> LSL and USL are provided, "
"and historical standard deviation is <b>unknown</b>."
msgstr ""
"El tamaño muestral tiene que ser <b>> 1</b> si se indican <b>tanto</b> LIE "
"como LSE, y la desviación típica histórica es <b>desconocida</b>."

msgid "<u>Decision:</u> <b>%s</b> lot."
msgstr "<u>Decisión:</u> <b>%s</b> lote."

#~ msgid ""
