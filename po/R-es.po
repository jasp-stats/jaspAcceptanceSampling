msgstr ""
"La probabilidad de aceptación (%1$.3f) al NCA (%2$.3f) es <b>menor</b> que "
"la probabilidad de aceptación requerida (%3$.3f) al NCA."

msgid ""
"Probability of acceptance (%1$.3f) at RQL (%2$.3f) is <b>higher</b> than the "
"required probability of acceptance (%3$.3f) at RQL."
msgstr ""
"La probabilidad de aceptación (%1$.3f) al NCR (%2$.3f) es <b>mayor</b> que "
"la probabilidad de aceptación requerida (%3$.3f) al NCR."

