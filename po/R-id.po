msgstr "Batas Spesifikasi Bawah (LSL)"

msgid "Upper Specification Limit (USL)"
msgstr "Batas Spesifikasi Atas (USL)"

msgid "Z.LSL"
msgstr "Z.LSL"

msgid "Z.USL"
msgstr "Z.USL"

msgid "Sample standard deviation has to be greater than 0."
msgstr "Deviasi standar sampel harus lebih besar dari 0."

msgid "Sample mean is invalid."
msgstr "Rerata sampel tidak valid."

msgid "Can not accept or reject lot: sample size has to be greater than 1."
msgstr ""
"Tidak dapat meneriman atau menolak lot: ukuran sampel harus lebih besar dari "
"1."

msgid ""
"Sample size has to be <b>> 1</b> if <b>both</b> LSL and USL are provided, "
"and historical standard deviation is <b>unknown</b>."
msgstr ""
"Ukuran sampel harus <b>> 1</b> jika <b>kedua</b> LSL dan USL diberikan, dan "
"deviasi standar historik <b>tidak diketahui</b>."

msgid "<u>Decision:</u> <b>%s</b> lot."
msgstr "<u>Keputusan:</u> <b>%s</b> lot."
