msgstr ""
"Jika jumlah item defektif dari %1$d disampel adalah <= %2$d, terima lot. "
"Tolak jika tidak."

msgid "Create Variable Plan"
msgstr "Buat Rencana Variabel"

msgid ""
"Z.LSL = (mean - LSL) / historical standard deviation\n"
"\n"
"Accept lot if Z.LSL >= k, otherwise reject."
msgstr ""
"Z.LSL = (rerata - LSL) / deviasi standar historis\n"
"\n"
"Terima lot jika Z.LSL >= k, jika tidak tolak."

msgid ""
"Variable plan generated for the current quality constraints is invalid. "
"Modify the quality constraints."
msgstr ""
"Rencana variabel dihasilkan untuk batasan kualitas saat ini tidak valid. "
"Modifikasikan batasan kualitas."

msgid ""
"Variable plan generated for the current quality constraints has an invalid "
